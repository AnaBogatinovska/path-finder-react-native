# MapTiler API key — get yours at https://cloud.maptiler.com/account/keys/
EXPO_PUBLIC_MAPTILER_API_KEY=your_maptiler_api_key_here

# Google Maps API key (required for Android react-native-maps SDK initialisation)
# Create one at https://console.cloud.google.com/ → APIs & Services → Credentials
# Also paste this key into app.json under android.config.googleMaps.apiKey
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
